{% extends "layout.twig" %}

{% block content %}

<h2>Добавить привычку</h2>

<form method="POST">

    <input type="text" name="title" placeholder="Название" required><br><br>

    <select name="category">
        <option value="health">Здоровье</option>
        <option value="study">Учёба</option>
        <option value="sport">Спорт</option>
    </select><br><br>

    <label>Приоритет:</label><br>
    <input type="checkbox" name="priority[]" value="low"> Low
    <input type="checkbox" name="priority[]" value="medium"> Medium
    <input type="checkbox" name="priority[]" value="high"> High

    <br><br>

    <button type="submit">Сохранить</button>

</form>

{% endblock %}